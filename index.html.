<div class="cookie-banner" id="cookieBanner">
  <span>Ce site n'utilise aucun cookie de tracking. Le localStorage est uniquement utilisé pour sauvegarder vos fragments localement sur votre appareil.</span>
  <div class="cookie-btns">
    <button class="cookie-accept" onclick="accepterCookies()">COMPRIS</button>
    <button class="cookie-decline" onclick="accepterCookies()">Fermer</button>
  </div>
</div>

<script>
// ── Scroll reveal ────────────────────────────────────
const io = new IntersectionObserver(entries => {
  entries.forEach(e => { if(e.isIntersecting) e.target.classList.add('visible'); });
}, { threshold:.12 });
document.querySelectorAll('.reveal').forEach(el => io.observe(el));

// ── FAQ toggle ───────────────────────────────────────
function toggleFaq(el) {
  const item = el.parentElement;
  const wasOpen = item.classList.contains('open');
  document.querySelectorAll('.faq-item').forEach(i => i.classList.remove('open'));
  if (!wasOpen) item.classList.add('open');
}

// ── Modale app ───────────────────────────────────────
// URLs des apps embarquées (même dossier ou inline)
const APPS = {
  lite:  { title:'FRAGMENT LITE', src:'fragment-lite_v2__1_.html' },
  elite: { title:'FRAGMENT ELITE 3.0', src:'Fragment_Elite_3_0_v2.html' },
  corp:  { title:'FRAGMENT CORPORATE', src:'fragment_corporate.html' }
};

function ouvrirApp(id) {
  const app = APPS[id];
  document.getElementById('modalTitle').textContent = app.title;
  document.getElementById('appFrame').src = app.src;
  document.getElementById('appModal').classList.add('open');
  document.body.style.overflow = 'hidden';
}
function fermerApp() {
  document.getElementById('appModal').classList.remove('open');
  document.getElementById('appFrame').src = '';
  document.body.style.overflow = '';
}
// Fermer en cliquant l'overlay
document.getElementById('appModal').addEventListener('click', function(e) {
  if (e.target === this) fermerApp();
});
// Fermer avec Escape
document.addEventListener('keydown', e => { if (e.key === 'Escape') fermerApp(); });

// ── Cookie banner ────────────────────────────────────
function accepterCookies() {
  document.getElementById('cookieBanner').classList.add('hidden');
  localStorage.setItem('frag_cookie_ok', '1');
}
if (localStorage.getItem('frag_cookie_ok')) {
  document.getElementById('cookieBanner').classList.add('hidden');
}

// ── Nav active link ───────────────────────────────────
const sections = document.querySelectorAll('section[id]');
const navLinks = document.querySelectorAll('.nav-links a');
const navObs = new IntersectionObserver(entries => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      navLinks.forEach(a => {
        a.style.color = a.getAttribute('href') === '#'+e.target.id ? 'var(--c1)' : '';
      });
    }
  });
}, { threshold:.3 });
sections.forEach(s => navObs.observe(s));
</script>
