</nav>

<!-- ── HERO ── -->
<section class="hero">
  <div class="container">
    <div class="hero-eyebrow">
      <span class="tag"><span class="tag-dot"></span>Chiffrement local · Zéro serveur</span>
    </div>
    <h1 class="hero-title">
      PROTÉGEZ<br>
      <span class="line2">VOS SECRETS<span class="flag">🇫🇷</span></span>
    </h1>
    <p class="hero-sub">
      FRAGMENT divise mathématiquement votre secret en <strong>deux fragments indépendants</strong>.
