<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<meta name="description" content="FRAGMENT — Système de fragmentation cryptographique XOR 100% local. Protégez vos secrets sans serveur.">
<title>FRAGMENT — Sécurité Souveraine 🇫🇷</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
/* ═══════════════════════════════════════════════════════
   FRAGMENT — SITE WEB COMPLET
   Police : Syne (display) + DM Mono (technique)
   Thème  : Bleu nuit profond + Cyan LED + Orange cuivré
   Style  : Industriel souverain / tech militaire épuré
═══════════════════════════════════════════════════════ */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

:root{
  --c1:#00d4ff;   /* cyan led */
  --c2:#ff8c42;   /* cuivre */
  --c3:#00e87a;   /* vert validation */
  --bg:#03060d;
  --bg2:#060c18;
  --bg3:#080f1f;
  --card:#0b1425;
  --card2:#0e1a2e;
  --border:rgba(0,212,255,.1);
  --border2:rgba(0,212,255,.2);
  --txt:#ddeeff;
  --muted:#5a88b0;
  --faint:#0d1e35;
  --syne:'Syne',sans-serif;
  --mono:'DM Mono',monospace;
}

html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--txt);font-family:var(--mono);font-size:15px;line-height:1.6;overflow-x:hidden}

/* Grille de fond globale */
body::before{
  content:'';position:fixed;inset:0;
  background-image:
    linear-gradient(rgba(0,212,255,.025) 1px,transparent 1px),
    linear-gradient(90deg,rgba(0,212,255,.025) 1px,transparent 1px);
  background-size:60px 60px;
  pointer-events:none;z-index:0
}

/* ── UTILITIES ── */
.container{max-width:1120px;margin:0 auto;padding:0 24px}
.container-sm{max-width:780px;margin:0 auto;padding:0 24px}
section{position:relative;z-index:1}

.tag{display:inline-flex;align-items:center;gap:6px;font-family:var(--mono);font-size:.6rem;font-weight:500;letter-spacing:2px;text-transform:uppercase;padding:4px 12px;border-radius:2px;border:1px solid var(--border2);color:var(--c1);background:rgba(0,212,255,.05)}
.tag-dot{width:5px;height:5px;border-radius:50%;background:var(--c1);animation:blink 2s infinite}
@keyframes blink{0%,100%{opacity:1}50%{opacity:.25}}

.section-label{font-family:var(--mono);font-size:.62rem;letter-spacing:3px;text-transform:uppercase;color:var(--c1);margin-bottom:14px;opacity:.7}
h2.section-title{font-family:var(--syne);font-size:clamp(1.8rem,4vw,2.8rem);font-weight:800;color:#fff;line-height:1.1;margin-bottom:20px}
h2.section-title span{color:var(--c1)}
.section-desc{font-size:.88rem;color:var(--muted);line-height:1.8;max-width:560px}

/* ── NAV ── */
nav{position:sticky;top:0;z-index:100;background:rgba(3,6,13,.88);border-bottom:1px solid var(--border);backdrop-filter:blur(16px)}
.nav-inner{display:flex;align-items:center;justify-content:space-between;padding:14px 24px;max-width:1120px;margin:0 auto}
.nav-logo{font-family:var(--syne);font-size:1.1rem;font-weight:800;letter-spacing:4px;color:#fff;text-decoration:none;display:flex;align-items:center;gap:10px}
.nav-logo-dot{width:8px;height:8px;border-radius:50%;background:var(--c1);box-shadow:0 0 8px var(--c1)}
.nav-links{display:flex;align-items:center;gap:28px}
.nav-links a{font-size:.65rem;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);text-decoration:none;transition:color .2s}
.nav-links a:hover{color:var(--c1)}
.nav-cta{font-family:var(--syne);font-size:.65rem;font-weight:700;letter-spacing:1px;padding:8px 20px;border:1px solid var(--c1);color:var(--c1);text-decoration:none;border-radius:2px;transition:all .2s}
.nav-cta:hover{background:var(--c1);color:#000}
@media(max-width:680px){.nav-links{display:none}}

/* ── HERO ── */
.hero{min-height:100vh;display:flex;flex-direction:column;justify-content:center;padding:120px 0 80px;position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;top:-20%;left:50%;transform:translateX(-50%);width:800px;height:800px;background:radial-gradient(circle,rgba(0,212,255,.08) 0%,transparent 65%);pointer-events:none}
.hero::after{content:'';position:absolute;bottom:-10%;right:-5%;width:500px;height:500px;background:radial-gradient(circle,rgba(255,140,66,.05) 0%,transparent 65%);pointer-events:none}

.hero-eyebrow{margin-bottom:24px}
.hero-title{font-family:var(--syne);font-size:clamp(2.8rem,8vw,6.5rem);font-weight:800;line-height:.95;letter-spacing:-2px;color:#fff;margin-bottom:28px}
.hero-title .line2{color:var(--c1);display:block}
.hero-title .flag{font-size:.6em;vertical-align:middle;margin-left:8px}
.hero-sub{font-size:1rem;color:var(--muted);line-height:1.8;max-width:540px;margin-bottom:40px}
.hero-sub strong{color:var(--txt)}

.hero-btns{display:flex;gap:14px;flex-wrap:wrap;margin-bottom:60px}
.btn-primary{font-family:var(--syne);font-size:.78rem;font-weight:700;letter-spacing:1px;padding:14px 32px;background:var(--c1);color:#000;border:none;cursor:pointer;text-decoration:none;display:inline-flex;align-items:center;gap:8px;transition:all .2s;border-radius:2px}
.btn-primary:hover{filter:brightness(1.1);transform:translateY(-1px);box-shadow:0 8px 24px rgba(0,212,255,.3)}
.btn-secondary{font-family:var(--syne);font-size:.78rem;font-weight:700;letter-spacing:1px;padding:14px 32px;background:transparent;color:var(--txt);border:1px solid var(--border2);cursor:pointer;text-decoration:none;display:inline-flex;align-items:center;gap:8px;transition:all .2s;border-radius:2px}
.btn-secondary:hover{border-color:var(--c1);color:var(--c1)}

.hero-stats{display:flex;gap:40px;flex-wrap:wrap}
.stat{display:flex;flex-direction:column;gap:4px}
.stat-num{font-family:var(--syne);font-size:1.8rem;font-weight:800;color:#fff}
.stat-lbl{font-size:.6rem;letter-spacing:2px;text-transform:uppercase;color:var(--muted)}

/* Barre d'état hero */
.hero-status{display:flex;align-items:center;gap:10px;padding:10px 18px;background:rgba(0,212,255,.05);border:1px solid var(--border);border-radius:2px;font-size:.62rem;letter-spacing:1.5px;color:var(--muted);width:fit-content;margin-bottom:40px}
.status-led{width:6px;height:6px;border-radius:50%;background:var(--c3);box-shadow:0 0 8px var(--c3);animation:blink 2.5s infinite}

/* ── DIVIDER ── */
.divider{border:none;border-top:1px solid var(--border);margin:0}

/* ── COMMENT ÇA MARCHE ── */
.how{padding:100px 0}
.how-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:var(--border);border:1px solid var(--border);margin-top:60px}
.how-step{background:var(--card);padding:36px 28px;position:relative}
.how-step:hover{background:var(--card2)}
.step-num{font-family:var(--syne);font-size:3.5rem;font-weight:800;color:rgba(0,212,255,.1);line-height:1;margin-bottom:16px}
.step-title{font-family:var(--syne);font-size:1rem;font-weight:700;color:#fff;margin-bottom:10px}
.step-desc{font-size:.78rem;color:var(--muted);line-height:1.7}
.step-tag{position:absolute;top:16px;right:16px}
@media(max-width:720px){.how-grid{grid-template-columns:1fr}}

/* ── VERSIONS ── */
.versions{padding:100px 0;background:var(--bg2)}
.versions-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;margin-top:60px}
@media(max-width:860px){.versions-grid{grid-template-columns:1fr}}

.version-card{background:var(--card);border:1px solid var(--border);padding:32px;position:relative;overflow:hidden;transition:transform .25s,border-color .25s}
.version-card:hover{transform:translateY(-4px);border-color:var(--border2)}
.version-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px}
.vc-lite::before{background:var(--c1)}
.vc-elite::before{background:linear-gradient(90deg,var(--c1),var(--c2))}
.vc-corp::before{background:var(--c2)}
.vc-featured{border-color:rgba(0,212,255,.3);box-shadow:0 0 30px rgba(0,212,255,.08)}

.vc-badge{font-size:.52rem;letter-spacing:2px;text-transform:uppercase;padding:3px 10px;border-radius:2px;margin-bottom:20px;display:inline-block;font-family:var(--mono);font-weight:500}
.badge-lite{background:rgba(0,212,255,.1);color:var(--c1);border:1px solid rgba(0,212,255,.2)}
.badge-elite{background:linear-gradient(90deg,rgba(0,212,255,.12),rgba(255,140,66,.12));color:#fff;border:1px solid rgba(255,255,255,.1)}
.badge-corp{background:rgba(255,140,66,.1);color:var(--c2);border:1px solid rgba(255,140,66,.2)}

.vc-name{font-family:var(--syne);font-size:1.5rem;font-weight:800;color:#fff;margin-bottom:8px}
.vc-desc{font-size:.78rem;color:var(--muted);line-height:1.7;margin-bottom:24px}

.vc-features{list-style:none;display:flex;flex-direction:column;gap:8px;margin-bottom:28px}
.vc-features li{font-size:.74rem;color:var(--muted);display:flex;align-items:flex-start;gap:10px;line-height:1.5}
.vc-features li::before{content:'✓';color:var(--c3);font-weight:700;flex-shrink:0;margin-top:2px}
.vc-features li.na{color:var(--faint)}
.vc-features li.na::before{content:'—';color:var(--faint)}

.vc-action{width:100%;padding:12px;font-family:var(--syne);font-size:.7rem;font-weight:700;letter-spacing:1px;cursor:pointer;border-radius:2px;text-align:center;text-decoration:none;display:block;transition:all .2s}
.va-lite{background:transparent;color:var(--c1);border:1px solid var(--c1)}
.va-lite:hover{background:rgba(0,212,255,.1)}
.va-elite{background:var(--c1);color:#000;border:1px solid var(--c1)}
.va-elite:hover{filter:brightness(1.1)}
.va-corp{background:transparent;color:var(--c2);border:1px solid var(--c2)}
.va-corp:hover{background:rgba(255,140,66,.1)}

/* ── SÉCURITÉ ── */
.security{padding:100px 0}
.security-grid{display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center;margin-top:60px}
@media(max-width:720px){.security-grid{grid-template-columns:1fr}}

.sec-visual{background:var(--card);border:1px solid var(--border);padding:32px;font-family:var(--mono);font-size:.72rem;color:var(--muted);line-height:2}
.sec-visual .comment{color:rgba(0,212,255,.4)}
.sec-visual .key{color:var(--c1)}
.sec-visual .val{color:var(--c3)}
.sec-visual .op{color:var(--c2)}
.code-line{display:flex;gap:16px;padding:4px 0;border-bottom:1px solid var(--faint)}
.code-num{color:var(--faint);user-select:none;min-width:24px;text-align:right}

.sec-points{display:flex;flex-direction:column;gap:20px}
.sec-point{display:flex;gap:16px;align-items:flex-start}
.sec-point-ico{width:36px;height:36px;border-radius:2px;background:rgba(0,212,255,.08);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;flex-shrink:0;font-size:1rem}
.sec-point-body{flex:1}
.sec-point-title{font-family:var(--syne);font-size:.9rem;font-weight:700;color:#fff;margin-bottom:4px}
.sec-point-desc{font-size:.74rem;color:var(--muted);line-height:1.6}

/* ── ALGO VISUEL ── */
.algo{padding:100px 0;background:var(--bg3)}
.algo-diagram{display:flex;align-items:center;gap:0;margin-top:60px;overflow-x:auto;padding-bottom:16px}
.algo-box{background:var(--card);border:1px solid var(--border);padding:20px 18px;min-width:140px;flex-shrink:0;text-align:center}
.algo-box-title{font-size:.52rem;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:8px}
.algo-box-val{font-family:var(--syne);font-size:1.1rem;font-weight:800;color:#fff}
.algo-box-sub{font-size:.5rem;color:var(--muted);margin-top:5px}
.algo-arrow{padding:0 12px;color:var(--c1);font-size:1.2rem;flex-shrink:0}
.algo-op{background:rgba(0,212,255,.08);border:1px solid var(--border2);padding:16px 14px;min-width:90px;flex-shrink:0;text-align:center;border-radius:2px}
.algo-op-sym{font-family:var(--syne);font-size:1.5rem;font-weight:800;color:var(--c1)}
.algo-op-lbl{font-size:.46rem;letter-spacing:1px;color:var(--muted);margin-top:3px}
.algo-result{display:flex;flex-direction:column;gap:8px;flex-shrink:0}
.algo-frag{background:var(--card);border:1px solid var(--border);padding:14px 16px;min-width:130px;border-radius:2px}
.algo-frag-a{border-left:3px solid var(--c1)}
.algo-frag-b{border-left:3px solid var(--c2)}
.algo-frag-lbl{font-size:.5rem;letter-spacing:1.5px;text-transform:uppercase;color:var(--muted);margin-bottom:4px}
.algo-frag-val{font-family:var(--mono);font-size:.65rem;color:var(--txt);word-break:break-all}

/* ── FAQ ── */
.faq{padding:100px 0}
.faq-list{margin-top:60px;display:flex;flex-direction:column;gap:2px}
.faq-item{background:var(--card);border:1px solid var(--border);overflow:hidden}
.faq-q{padding:22px 24px;cursor:pointer;display:flex;justify-content:space-between;align-items:center;gap:16px;transition:background .2s}
.faq-q:hover{background:var(--card2)}
.faq-q-txt{font-family:var(--syne);font-size:.9rem;font-weight:600;color:#fff}
.faq-icon{color:var(--c1);font-size:1.1rem;flex-shrink:0;transition:transform .25s;font-family:var(--mono)}
.faq-item.open .faq-icon{transform:rotate(45deg)}
.faq-a{max-height:0;overflow:hidden;transition:max-height .35s ease}
.faq-item.open .faq-a{max-height:400px}
.faq-a-inner{padding:0 24px 22px;font-size:.8rem;color:var(--muted);line-height:1.8}
.faq-a-inner strong{color:var(--txt)}
.faq-a-inner a{color:var(--c1);text-decoration:underline}
.faq-a-inner code{font-family:var(--mono);background:var(--faint);padding:2px 6px;border-radius:2px;font-size:.75rem;color:var(--c1)}

/* ── CONFORMITÉ / LEGAL ── */
.legal{padding:100px 0;background:var(--bg2)}
.legal-grid{display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-top:60px}
@media(max-width:680px){.legal-grid{grid-template-columns:1fr}}
.legal-card{background:var(--card);border:1px solid var(--border);padding:28px}
.legal-card-ico{font-size:1.6rem;margin-bottom:14px}
.legal-card-title{font-family:var(--syne);font-size:1rem;font-weight:700;color:#fff;margin-bottom:10px}
.legal-card-body{font-size:.76rem;color:var(--muted);line-height:1.8}
.legal-card-body strong{color:var(--txt)}
.legal-card-body ul{list-style:none;margin-top:8px;display:flex;flex-direction:column;gap:5px}
.legal-card-body li::before{content:'→ ';color:var(--c1)}
.legal-card-body a{color:var(--c1)}

/* ── CTA FINAL ── */
.cta-section{padding:120px 0;text-align:center;position:relative;overflow:hidden}
.cta-section::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 80% 60% at 50% 50%,rgba(0,212,255,.05) 0%,transparent 70%)}
.cta-title{font-family:var(--syne);font-size:clamp(2rem,5vw,4rem);font-weight:800;color:#fff;line-height:1;margin-bottom:20px}
.cta-desc{font-size:.88rem;color:var(--muted);margin-bottom:40px;line-height:1.8}
.cta-btns{display:flex;gap:16px;justify-content:center;flex-wrap:wrap}

/* ── FOOTER ── */
footer{background:var(--bg);border-top:1px solid var(--border);padding:48px 0 32px}
.footer-inner{max-width:1120px;margin:0 auto;padding:0 24px}
.footer-top{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:40px;margin-bottom:48px}
@media(max-width:768px){.footer-top{grid-template-columns:1fr 1fr}}
.footer-brand{font-family:var(--syne);font-size:1.2rem;font-weight:800;letter-spacing:4px;color:#fff;margin-bottom:12px}
.footer-tagline{font-size:.7rem;color:var(--muted);line-height:1.7;max-width:260px}
.footer-col-title{font-family:var(--syne);font-size:.7rem;font-weight:700;letter-spacing:2px;text-transform:uppercase;color:var(--muted);margin-bottom:14px}
.footer-links{list-style:none;display:flex;flex-direction:column;gap:8px}
.footer-links a{font-size:.74rem;color:var(--muted);text-decoration:none;transition:color .2s}
.footer-links a:hover{color:var(--c1)}
.footer-bottom{border-top:1px solid var(--border);padding-top:24px;display:flex;justify-content:space-between;align-items:center;flex-wrap:gap;gap:12px;font-size:.65rem;color:var(--muted)}
.footer-copy span{color:var(--c1)}
.footer-legal{display:flex;gap:20px}
.footer-legal a{color:var(--muted);text-decoration:none;transition:color .2s}
.footer-legal a:hover{color:var(--c1)}

/* ── MODALE APPS ── */
.modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.85);z-index:1000;display:none;align-items:center;justify-content:center;padding:20px;backdrop-filter:blur(8px)}
.modal-overlay.open{display:flex}
.modal-box{background:var(--card);border:1px solid var(--border2);max-width:680px;width:100%;max-height:90vh;overflow-y:auto;position:relative}
.modal-header{padding:24px 28px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between}
.modal-title{font-family:var(--syne);font-size:1.1rem;font-weight:700;color:#fff}
.modal-close{background:none;border:none;color:var(--muted);font-size:1.4rem;cursor:pointer;padding:4px;line-height:1;transition:color .2s}
.modal-close:hover{color:#fff}
.modal-body{padding:28px}

/* Onglets dans la modale */
.app-tabs{display:flex;gap:4px;background:var(--bg);border:1px solid var(--border);padding:4px;border-radius:2px;margin-bottom:20px}
.app-tab{flex:1;padding:9px 0;text-align:center;font-size:.62rem;font-weight:600;letter-spacing:1px;text-transform:uppercase;cursor:pointer;border-radius:1px;color:var(--muted);transition:all .2s;font-family:var(--mono)}
.app-tab.active{background:var(--c1);color:#000}

.app-panel{display:none}
.app-panel.active{display:block}

/* ── IFRAME WRAPPER ── */
.app-frame{width:100%;min-height:600px;border:none;display:block;background:var(--bg)}

/* ── SCROLL REVEAL ── */
.reveal{opacity:0;transform:translateY(24px);transition:opacity .6s ease,transform .6s ease}
.reveal.visible{opacity:1;transform:translateY(0)}

/* ── COOKIE BANNER ── */
.cookie-banner{position:fixed;bottom:0;left:0;right:0;background:var(--card);border-top:1px solid var(--border);padding:16px 24px;z-index:200;display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;font-size:.72rem;color:var(--muted)}
.cookie-banner.hidden{display:none}
.cookie-btns{display:flex;gap:10px;flex-shrink:0}
.cookie-accept{padding:7px 18px;background:var(--c1);color:#000;border:none;cursor:pointer;font-family:var(--syne);font-size:.65rem;font-weight:700;letter-spacing:.5px;border-radius:2px}
.cookie-decline{padding:7px 14px;background:transparent;color:var(--muted);border:1px solid var(--border);cursor:pointer;font-size:.65rem;border-radius:2px}
</style>
</head>
<body>

<!-- ── NAVIGATION ── -->
<nav>
  <div class="nav-inner">
    <a href="#" class="nav-logo">
      <span class="nav-logo-dot"></span>
      FRAGMENT
    </a>
    <div class="nav-links">
      <a href="#comment">Fonctionnement</a>
      <a href="#versions">Versions</a>
      <a href="#securite">Sécurité</a>
